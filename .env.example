# Salone Hub Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# CONVEX & DATABASE CONFIGURATION
# =============================================================================
CONVEX_DEPLOYMENT=fortunate-sandpiper-477
CONVEX_SITE_URL=http://localhost:3170

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secrets - Generate strong random strings (minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-long
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-minimum-32-chars-long

# Session Configuration
SESSION_EXPIRY_DAYS=7
REFRESH_TOKEN_EXPIRY_DAYS=30

# =============================================================================
# EXTERNAL APIS & SERVICES
# =============================================================================
# Government API Endpoints (if any)
GOVERNMENT_API_BASE_URL=https://api.gov.sl
GOVERNMENT_API_KEY=your-government-api-key

# Email Service (if using)
EMAIL_SERVICE_PROVIDER=sendgrid
EMAIL_SERVICE_API_KEY=your-email-service-api-key
EMAIL_FROM_ADDRESS=noreply@salonehub.gov.sl

# Analytics (if using)
ANALYTICS_PROVIDER=google
ANALYTICS_API_KEY=your-analytics-api-key

# Storage (if using cloud storage)
STORAGE_PROVIDER=aws
STORAGE_BUCKET_NAME=salonehub-documents
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key

# =============================================================================
# FRONTEND CONFIGURATION (NEXT_PUBLIC_*)
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3170
NEXT_PUBLIC_APP_NAME=Salone Hub
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SUPPORT_EMAIL=support@salonehub.gov.sl
NEXT_PUBLIC_GOVERNMENT_WEBSITE=https://www.gov.sl

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info
ENABLE_DEBUG_LOGGING=false

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=20